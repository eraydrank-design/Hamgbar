rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Profile photos ────────────────────────────────────────────────────────
    // Each user may read/write only their own photo directory.
    match /profile-photos/{userId}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Cocktail images ───────────────────────────────────────────────────────
    // Only authenticated users can read; admins can write.
    match /cocktail-images/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Explore posts ─────────────────────────────────────────────────────────
    // Staff and admin can upload post images.
    match /explore-posts/{userId}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
